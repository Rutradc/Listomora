@page "/ingredient/list"
@using ListomoraFront.Models
@using ListomoraFront.Models.Ingredients

<PageTitle>Listomora - Ingrédients</PageTitle>

<MudTable Items="@Ingredients" FixedHeader="true" FixedFooter="true" Dense="false" Hover="true" Filter="new Func<IngredientListDto, bool>(FilterFunc1)" @bind-SelectedItem="selectedIngredient1" Class="ma-4">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Ingredients</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Recherche" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nom</MudTh>
        <MudTh>Catégorie</MudTh>
        <MudTh>Nom créateur</MudTh>
        <MudTh><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GoToCreate())">Ajouter</MudButton></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Catégorie">@context.Category.ToDescription()</MudTd>
        <MudTd DataLabel="Nom créateur">@context.CreatorName</MudTd>
        <MudTd><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GoToDetails(context.Id))">Détails</MudButton></MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
