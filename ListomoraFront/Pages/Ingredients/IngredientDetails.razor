@page "/ingredient/details/{sourceUrl}/{id:guid}"
@using ListomoraFront.Models.Ingredients
<PageTitle>Listomora - Détails ingredient</PageTitle>

<MudPaper Class="pa-4" Elevation="4">
    <MudText Typo="Typo.h4">Détails d'ingredient</MudText>

    @if (Ingredient is not null)
    {
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Nom</MudText>
                <MudText Typo="Typo.body1">@Ingredient.Name</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Catégorie</MudText>
                <MudText Typo="Typo.body1">@Ingredient.Category.ToDescription()</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Est public</MudText>
                <MudText Typo="Typo.body1">@Ingredient.IsPublic</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Nom créateur</MudText>
                <MudText Typo="Typo.body1">@Ingredient.CreatorName</MudText>
            </MudItem>
        </MudGrid>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               OnClick="() => GoToList()"
               Class="mt-4 mx-auto d-block"
               Size="Size.Medium">
        Retour à la liste
    </MudButton>
</MudPaper>