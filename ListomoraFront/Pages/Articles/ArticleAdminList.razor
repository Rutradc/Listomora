@page "/article/adminlist"
@using ListomoraFront.Models.Articles

<PageTitle>Listomora - Articles Admin</PageTitle>

<MudTable Items="@Articles" FixedHeader="true" FixedFooter="true" Dense="false" Hover="true" Filter="new Func<ArticleDetailsDto, bool>(FilterFunc1)" @bind-SelectedItem="selectedArticle1" Class="ma-4">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Articles</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Recherche" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nom</MudTh>
        <MudTh>Public</MudTh>
        <MudTh>Nom créateur</MudTh>
        <MudTh></MudTh>
        <MudTh></MudTh>
        <MudTh><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GoToCreate())">Ajouter</MudButton></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Public"><MudIcon Icon="@(context.IsPublic ? "fas fa-check" : "fas fa-xmark")"/></MudTd>
        <MudTd DataLabel="Nom créateur">@context.CreatorName</MudTd>
        <MudTd><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GoToDetails(context.Id))">Détails</MudButton></MudTd>
        <MudTd><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GoToUpdate(context.Id))">Modifier</MudButton></MudTd>
        <MudTd><MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(async () => Delete(context.Id))">Supprimer</MudButton></MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>