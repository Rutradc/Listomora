@page "/article/details/{sourceUrl}/{id:guid}"
<PageTitle>Listomora - Détails article</PageTitle>

<MudPaper Class="pa-4" Elevation="4">
    <MudText Typo="Typo.h4">Détails d'article</MudText>

    @if (Article is not null)
    {
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Nom</MudText>
                <MudText Typo="Typo.body1">@Article.Name</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Est public</MudText>
                <MudText Typo="Typo.body1">@Article.IsPublic</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.h6">Nom créateur</MudText>
                <MudText Typo="Typo.body1">@Article.CreatorName</MudText>
            </MudItem>
        </MudGrid>
    }

    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               OnClick="() => GoToList()"
               Class="mt-4 mx-auto d-block"
               Size="Size.Medium">
        Retour à la liste
    </MudButton>
</MudPaper>