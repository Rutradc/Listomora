@using ListomoraFront.Models.Users
@using ListomoraFront.Services.Interfaces
<MudNavMenu Class="mud-width-full" Color="Color.Dark">
    <MudNavLink Href="/" Icon="fas fa-house" IconColor="Color.Dark">
        <MudText Color="Color.Dark">Accueil</MudText>
    </MudNavLink>

    @if (!IsConnected)
    {
        <MudNavLink Href="/login" Icon="fas fa-right-to-bracket" IconColor="Color.Dark">
            <MudText Color="Color.Dark">Se connecter</MudText>
        </MudNavLink>
        <MudNavLink Href="/register" Icon="fas fa-user-plus" IconColor="Color.Dark">
            <MudText Color="Color.Dark">Créer un compte</MudText>
        </MudNavLink>
    }
    else
    {
        <MudNavGroup Icon="fas fa-shop" IconColor="Color.Dark" Expanded="false">
            <TitleContent>
                <MudText Color="Color.Dark">Articles</MudText>
            </TitleContent>
            <ChildContent>
                <MudNavLink Href="/article/list" Icon="fas fa-list-ul" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Liste d'articles</MudText>
                </MudNavLink>
                <MudNavLink Href="/article/mine" Icon="fas fa-list-ul" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Mes articles</MudText>
                </MudNavLink>
                @if(User.Role == UserRole.ADMIN)
                {
                    <MudNavLink Href="/article/adminlist" Icon="fas fa-list-ul" IconColor="Color.Dark">
                        <MudText Color="Color.Dark">Liste admin d'articles</MudText>
                    </MudNavLink>
                }
                <MudNavLink Href="/article/create/list" Icon="fas fa-square-plus" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Ajouter un article</MudText>
                </MudNavLink>
            </ChildContent>
        </MudNavGroup>
        <MudNavGroup Icon="fas fa-seedling" IconColor="Color.Dark" Expanded="false">
            <TitleContent>
                <MudText Color="Color.Dark">Ingredients</MudText>
            </TitleContent>
            <ChildContent>
                <MudNavLink Href="/ingredient/list" Icon="fas fa-list-ul" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Liste d'ingredients</MudText>
                </MudNavLink>
                <MudNavLink Href="/ingredient/mine" Icon="fas fa-list-ul" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Mes ingredients</MudText>
                </MudNavLink>
                @if(User.Role == UserRole.ADMIN)
                {
                    <MudNavLink Href="/ingredient/adminlist" Icon="fas fa-list-ul" IconColor="Color.Dark">
                        <MudText Color="Color.Dark">Liste admin d'ingredients</MudText>
                    </MudNavLink>
                }
                <MudNavLink Href="/ingredient/create/list" Icon="fas fa-square-plus" IconColor="Color.Dark">
                    <MudText Color="Color.Dark">Ajouter un ingredient</MudText>
                </MudNavLink>
            </ChildContent>
        </MudNavGroup>
        <MudNavLink OnClick="@Logout" Icon="fas fa-right-from-bracket" IconColor="Color.Dark">
            <MudText Color="Color.Dark">Se déconnecter</MudText>
        </MudNavLink>
    }
</MudNavMenu>
